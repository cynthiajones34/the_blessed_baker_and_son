rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Orders — open read/write (admin panel + order forms)
    match /orders/{document=**} {
      allow read, write: if true;
    }

    // Newsletter subscribers — public write, admin panel read
    match /subscribers/{document=**} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Email campaigns — admin panel read/write
    match /emailCampaigns/{document=**} {
      allow read, write: if true;
    }

    // Standing orders — customer creates via order form, admin panel reads/updates
    // Functions use admin SDK (bypasses rules). Hardening deferred to T7.
    match /standingOrders/{document=**} {
      allow read, write: if true;
    }

  }
}
